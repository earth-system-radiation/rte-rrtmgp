#!@SHELL@

set -e

@TESTS_ENABLED_FALSE@exit 77

(unset CDPATH) >/dev/null 2>&1 && unset CDPATH
cd '@abs_builddir@'

RRTMGP_DATA=${RRTMGP_DATA-'@abs_top_builddir@/@testcachedir@'}

inputs='
rrtmgp-aerosols-merra-lw.nc
rrtmgp-aerosols-merra-sw.nc
rrtmgp-clouds-lw.nc
rrtmgp-clouds-sw.nc
rrtmgp-gas-lw-g256.nc
rrtmgp-gas-sw-g224.nc
'

for input in ${inputs}; do
  filename=`echo "${input}" | sed 's|.*/||'`
  test -f "${filename}" || @LN_S@ "${RRTMGP_DATA}/${input}" "${filename}"
done

@LAUNCH_PREFIX@ @SHELL@ - <<_EOF
set -e
./rrtmgp_allsky@EXEEXT@ 24 72 1 rrtmgp-allsky-lw.nc rrtmgp-gas-lw-g256.nc rrtmgp-clouds-lw.nc rrtmgp-aerosols-merra-lw.nc
./rrtmgp_allsky@EXEEXT@ 24 72 1 rrtmgp-allsky-sw.nc rrtmgp-gas-sw-g224.nc rrtmgp-clouds-sw.nc rrtmgp-aerosols-merra-sw.nc
./rrtmgp_allsky@EXEEXT@ 24 72 1 rrtmgp-allsky-lw-no-aerosols.nc rrtmgp-gas-lw-g256.nc rrtmgp-clouds-lw.nc
./rrtmgp_allsky@EXEEXT@ 24 72 1 rrtmgp-allsky-sw-no-aerosols.nc rrtmgp-gas-sw-g224.nc rrtmgp-clouds-sw.nc
_EOF

@SP_ENABLED_FALSE@FAILURE_THRESHOLD='7.e-4'
@SP_ENABLED_TRUE@FAILURE_THRESHOLD='3.5e-1'
export FAILURE_THRESHOLD
@PYTHON@ '@abs_top_srcdir@/examples/compare-to-reference.py' --ref_dir "${RRTMGP_DATA}/examples/all-sky/reference" --var lw_flux_up lw_flux_dn sw_flux_up sw_flux_dn sw_flux_dir --file rrtmgp-allsky-lw.nc rrtmgp-allsky-sw.nc
@PYTHON@ '@abs_top_srcdir@/examples/compare-to-reference.py' --ref_dir "${RRTMGP_DATA}/examples/all-sky/reference" --var lw_flux_up lw_flux_dn sw_flux_up sw_flux_dn sw_flux_dir --file rrtmgp-allsky-lw-no-aerosols.nc rrtmgp-allsky-sw-no-aerosols.nc
