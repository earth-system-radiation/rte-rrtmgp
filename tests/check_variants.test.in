#!@SHELL@

set -e

@TESTS_ENABLED_FALSE@exit 77

(unset CDPATH) >/dev/null 2>&1 && unset CDPATH
cd '@abs_builddir@'

# The tests write to the input file, therefore we copy it instead of symlinking:
inoutput='test_atmospheres.nc'
cp multiple_input4MIPs_radiation_RFMIP_UColorado-RFMIP-1-2_none.nc "${inoutput}"

@LAUNCH_PREFIX@ @SHELL@ - <<_EOF
set -e
./check_variants@EXEEXT@ "${inoutput}" rrtmgp-gas-lw-g256.nc rrtmgp-gas-lw-g128.nc
./check_variants@EXEEXT@ "${inoutput}" rrtmgp-gas-sw-g224.nc rrtmgp-gas-sw-g112.nc
_EOF
